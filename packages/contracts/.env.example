# Mini-DEX Soroban Smart Contracts Environment Variables
# Copy this file to .env for local development
# DO NOT commit .env to the repository!

# ============================================
# Stellar Soroban Configuration
# ============================================

# Stellar Network (testnet or mainnet)
STELLAR_NETWORK=testnet

# Stellar RPC URL for Soroban
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Network Passphrase
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ============================================
# Deployment Wallet Configuration
# ============================================

# Soroban identity name (created with: soroban keys generate <name>)
# ⚠️ SECURITY WARNING:
# - DO NOT commit actual private keys to the repository
# - Use a dedicated deployment identity (not your personal wallet)
# - Ensure the account has sufficient XLM for transaction fees
# - Get free testnet XLM from: https://laboratory.stellar.org/#account-creator?network=test
# SOROBAN_IDENTITY=deployer

# ============================================
# Local Development Notes
# ============================================
# 1. Copy this file to .env
# 2. Install Soroban CLI: cargo install --locked soroban-cli
# 3. Generate identity: soroban keys generate deployer --network testnet
# 4. Fund account: soroban keys fund deployer --network testnet
# 5. Never commit .env to version control

# ============================================
# Deployment Commands
# ============================================
# Build contract:
#   cargo build --target wasm32-unknown-unknown --release
#
# Optimize WASM:
#   soroban contract optimize --wasm target/wasm32-unknown-unknown/release/mini_dex.wasm
#
# Deploy contract:
#   soroban contract deploy \
#     --wasm target/wasm32-unknown-unknown/release/mini_dex.wasm \
#     --source deployer \
#     --network testnet
#
# Run tests:
#   cargo test

